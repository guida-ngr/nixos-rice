set $mod Mod4
font pango:Open Sans 8

#  auto start  #
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec --no-startup-id nm-applet
exec --no-startup-id autotiling
exec_always --no-startup-id swww-daemon

#  ws  #
# set ws
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
# switch ws
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
# window -> ws
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7

#  window  #
# appearance
default_border none
gaps inner     10
corner_radius  10
blur           enable
blur_passes    3
blur_radius    5
# resize window
bindsym $mod+Shift+z mode "resize"
mode "resize" {
        bindsym l resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym $mod+Shift+z mode "default"
}
# focus window
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
# move windown
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
# change container layout (stacked, tabbed, split)
bindsym $mod+z layout stacking
bindsym $mod+x layout tabbed
bindsym $mod+c layout toggle split
# enter fullscreen mode for the focused container
bindsym $mod+F11 fullscreen toggle
# float
bindsym $mod+space floating toggle
bindsym $mod+Shift+space focus mode_toggle
# drag window
floating_modifier $mod
# classes
for_window [app_id="float"] {
    floating enable
    resize set 800 500
    move position center
}

#  keybinds  #
# sys
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'exit sway?' -B 'yeah' 'swaymsg exit'
bindsym $mod+q kill
# rice
bindsym $mod+r  exec kitty -e nvim ~/.config
bindsym $mod+F1 exec kitty -e sudo nvim /etc/nixos/configuration.nix
bindsym $mod+F2 exec kitty -e nvim ~/.config/sway/config
bindsym $mod+F3 exec kitty -e nvim ~/.config/quickshell
bindsym $mod+F4 exec kitty -e sudo nvim /etc/nixos/flake.nix
bindsym $mod+F5 exec kitty -e nvim ~/.bashrc
# app
bindsym $mod+Return exec kitty
bindsym $mod+Shift+Return exec kitty --class float
bindsym $mod+d exec wofi --show drun
bindsym $mod+s exec kitty -e ranger
bindsym $mod+p exec kooha
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy
bindsym $mod+f exec firefox
bindsym $mod+o exec obsidian

# audio #
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status

# layout bar #
client.focused              #333333 #333333 #ffffff
client.unfocused            #181818 #181818 #888888
